library ieee;
use IEEE.STD_LOGIC_1164.all;

entity mux4x1 is
	Port (
		-- Input
		X : in bit_vector (3 downto 0);
		Sel : in bit_vector (1 downto 0);
		-- Output
		Y : out bit
		);
				
end mux4x1;

architecture v_logica_pura of mux4x1 is
begin
Y <= (X(0) and (not Sel(1)) and (not Sel(0))) or ;
end v_logica_pura;